    {
      "name": "02 - Authentication",
      "item": [
        {
          "name": "[POST] Token Creation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    });\r",
                  "\r",
                  "// extracting token\r",
                  "const resposta = pm.response.json();\r",
                  "\r",
                  "// storing token in environment variable\r",
                  "if(resposta.token) {\r",
                  "    pm.environment.set(\"token\", resposta.token);\r",
                  "    console.log(\"Token has been successfully stored: \" + resposta.token);\r",
                  "} else {\r",
                  "    console.log(\"Error: Token not found\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\" : \"admin\",\r\n    \"password\" : \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/auth",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "03 - Booking Management",
      "item": [
        {
          "name": "[POST] Booking Creation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 (booking created)\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    });\r",
                  "\r",
                  "// extracting the response\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "// checking\r",
                  "pm.test(\"Response contains numeric ID\", function () {\r",
                  "    pm.expect(response.bookingid).to.be.a('number');\r",
                  "});\r",
                  "\r",
                  "// storing the bookingid as environment variable\r",
                  "if(response.bookingid) {\r",
                  "    pm.environment.set(\"bookingid\", response.bookingid);\r",
                  "    pm.environment.set(\"lastName\", response.booking.lastname);\r",
                  "    console.log(\"Booking ID and related Last Name registered: \" + response.bookingid + \" \" + response.booking.lastname);\r",
                  "} else {\r",
                  "    console.log(\"Error: bookingid field not found\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"Joao\",\r\n    \"lastname\" : \"MacielTester147\",\r\n    \"totalprice\" : 2899,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2026-08-30\",\r\n        \"checkout\" : \"2026-09-12\"\r\n    },\r\n    \"additionalneeds\" : \"Utmost privacy\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/booking",
              "host": [
                "{{url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[GET] Filter By Last Name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// checking if the response contains the expected data\r",
                  "const bookingsList = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Search returned at least one booking\", function () {\r",
                  "    pm.expect(bookingsList.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "// checking if the saved id is in the search results\r",
                  "pm.test(\"The created booking ID is present in the search results\", function () {\r",
                  "    const createdId = Number(pm.environment.get(\"bookingid\"));\r",
                  "    const isIdPresent = bookingsList.some(item => item.bookingid === createdId);\r",
                  "    \r",
                  "    pm.expect(isIdPresent).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url}}/booking?lastname={{lastName}}",
              "host": [
                "{{url}}"
              ],
              "path": [
                "booking"
              ],
              "query": [
                {
                  "key": "lastname",
                  "value": "{{lastName}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "[PUT] Full Booking Update",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const updatedBooking = pm.response.json();\r",
                  "\r",
                  "// functional validation for both updates (price and checkout)\r",
                  "pm.test(\"Price was updated to 5000\", function () {\r",
                  "    pm.expect(updatedBooking.totalprice).to.equal(5000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Checkout date was updated to 2026-09-16\", function () {\r",
                  "    pm.expect(updatedBooking.bookingdates.checkout).to.equal(\"2026-09-16\");\r",
                  "});\r",
                  "\r",
                  "// integrity validation\r",
                  "pm.test(\"Lastname is unchanged\", function () {\r",
                  "    pm.expect(updatedBooking.lastname).to.equal(pm.environment.get(\"lastName\"));\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Cookie",
                "value": "token={{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"Joao\",\r\n    \"lastname\" : \"MacielTester147\",\r\n    \"totalprice\" : 5000,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2026-08-30\",\r\n        \"checkout\" : \"2026-09-16\"\r\n    },\r\n    \"additionalneeds\" : \"Utmost privacy\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/booking/{{bookingid}}",
              "host": [
                "{{url}}"
              ],
              "path": [
                "booking",
                "{{bookingid}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "[PATCH] Partial Booking Update",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const patchedBooking = pm.response.json();\r",
                  "\r",
                  "// functional validation\r",
                  "pm.test(\"Firstname was updated via PATCH\", function () {\r",
                  "    pm.expect(patchedBooking.firstname).to.equal(\"JOAO\");\r",
                  "});\r",
                  "\r",
                  "// persistance validations\r",
                  "pm.test(\"Lastname remained unchanged\", function () {\r",
                  "    pm.expect(patchedBooking.lastname).to.equal(pm.environment.get(\"lastName\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total price remained the same as previous update\", function () {\r",
                  "    pm.expect(patchedBooking.totalprice).to.equal(5000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
