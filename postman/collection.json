      "item": [
        {
          "name": "[GET] Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "    });\r",
                  "\r",
                  "// checking response\r",
                  "if(pm.response.text() == \"Created\") {\r",
                  "    console.log(\"API is up and running\");\r",
                  "} else {\r",
                  "    console.log(\"Error: API might be down\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url}}/ping",
              "host": [
                "{{url}}"
              ],
              "path": [
                "ping"
              ]
            }
          },
          "response": []
        }
